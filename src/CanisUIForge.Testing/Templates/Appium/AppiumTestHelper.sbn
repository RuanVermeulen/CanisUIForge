        }
    }

    public static void WaitForElement(AndroidDriver driver, string automationId, int timeoutSeconds = 10)
    {
        WebDriverWait wait = new WebDriverWait(driver, TimeSpan.FromSeconds(timeoutSeconds));
        wait.Until(drv =>
        {
            try
            {
                IWebElement element = drv.FindElement(MobileBy.AccessibilityId(automationId));
                return element.Displayed;
            }
            catch (NoSuchElementException)
            {
                return false;
            }
        });
    }

    public static void EnterText(AndroidDriver driver, string automationId, string text)
    {
        IWebElement? element = FindByAutomationId(driver, automationId);
        Assert.NotNull(element);
        element!.Clear();
        element.SendKeys(text);
    }

    public static void TapElement(AndroidDriver driver, string automationId)
    {
        IWebElement? element = FindByAutomationId(driver, automationId);
        Assert.NotNull(element);
        element!.Click();
