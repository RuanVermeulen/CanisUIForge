    public static IWebElement? FindByAutomationId(AndroidDriver driver, string automationId, int timeoutSeconds = 10)
    {
        WebDriverWait wait = new WebDriverWait(driver, TimeSpan.FromSeconds(timeoutSeconds));
        IWebElement element = wait.Until(drv =>
        {
            try
            {
                return drv.FindElement(MobileBy.AccessibilityId(automationId));
            }
            catch (NoSuchElementException)
            {
                return null!;
            }
        });
        return element;
    }

    public static bool IsElementDisplayed(AndroidDriver driver, string automationId)
    {
        try
