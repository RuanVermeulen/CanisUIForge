namespace {{NamespaceRoot}}.Blazor.Tests.Playwright;

public static class PlaywrightTestHelper
{
    public static async Task<IPage> NavigateToPageAsync(PlaywrightFixture fixture, string relativePath)
    {
        IPage page = await fixture.CreatePageAsync();
        IResponse? response = await page.GotoAsync($"{fixture.BaseUrl}/{relativePath}");
        Assert.NotNull(response);
        Assert.True(response!.Ok, $"Navigation to '{relativePath}' failed with status {response.Status}.");
        return page;
    }

    public static ILocator GetByTestId(IPage page, string testId)
    {
        return page.Locator($"[data-testid=\"{testId}\"]");
    }

    public static async Task WaitForTestIdAsync(IPage page, string testId, float timeoutMs = 10000)
    {
        await page.Locator($"[data-testid=\"{testId}\"]").WaitForAsync(new LocatorWaitForOptions
        {
            Timeout = timeoutMs
        });
    }

    public static async Task FillFormFieldAsync(IPage page, string fieldName, string value)
    {
        ILocator field = page.Locator($"[name=\"{fieldName}\"], [id=\"{fieldName}\"]").First;
        await field.FillAsync(value);
    }

    public static async Task ClickSubmitAsync(IPage page)
    {
        ILocator submitButton = GetByTestId(page, "submit-button");
        await submitButton.ClickAsync();
    }

    public static async Task ClickCancelAsync(IPage page)
    {
        ILocator cancelButton = GetByTestId(page, "cancel-button");
        await cancelButton.ClickAsync();
    }
}
